# Supabase — client-safe (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Supabase OAuth: enable Google + GitHub providers in Supabase dashboard
# Set Site URL to http://localhost:3456 (dev) and production URL
# Add authorized redirect URLs: http://localhost:3456/** and https://*.vercel.app/**

# AI Configuration
# The app tries providers in this order:
# 1. Anthropic
# 2. Groq
# 3. Hugging Face Zephyr

# Anthropic key (server-side)
ANTHROPIC_API_KEY=
# Anthropic key (client-side, dev-only)
NEXT_PUBLIC_ANTHROPIC_API_KEY=

# Groq token
NEXT_PUBLIC_GROQ_API_KEY=
NEXT_PUBLIC_GROQ_MODEL=llama-3.1-8b-instant

# Hugging Face token
NEXT_PUBLIC_HF_TOKEN=
NEXT_PUBLIC_HF_MODEL=HuggingFaceH4/zephyr-7b-beta
